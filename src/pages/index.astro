---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Marquee from '../components/sections/Marquee.astro';
import ServicesOverview from '../components/sections/ServicesOverview.astro';
import Process from '../components/sections/Process.astro';
import PricingTeaser from '../components/sections/PricingTeaser.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import GotAnIdea from '../components/sections/GotAnIdea.astro';
---
<BaseLayout title="SiteGenius — Web Design for NZ Businesses">
  <Hero />
  <Marquee />
  <ServicesOverview />
  <Process />
  <PricingTeaser />
  <Testimonials />
  <GotAnIdea />

  <section class="py-12 flex justify-center items-center">
    <a href="/404" class="inline-flex flex-col items-center gap-3 group opacity-60 hover:opacity-100 transition-opacity">
      <div class="relative h-16 w-16 rounded-full border border-dashed border-neon-cyan/50 group-hover:border-neon-cyan group-hover:bg-neon-cyan/10 flex items-center justify-center transition-all animate-pulse-glow">
        <span class="absolute h-6 w-6 bg-rose-500 rounded-full shadow-[0_0_15px_rgba(244,63,94,0.6)] group-hover:scale-95 transition-transform"></span>
      </div>
      <span class="text-[10px] uppercase tracking-[0.3em] font-mono text-muted-300 group-hover:text-rose-500 font-bold transition-colors">Do Not Touch</span>
    </a>
  </section>

  <CTABanner
    title="Ready to get online"
    description="Let's build something your customers will love."
    href="/get-a-quote"
    label="Get Your Free Quote"
  />
</BaseLayout>
