---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingCard from '../components/ui/PricingCard.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import { services } from '../data/services';
import { hostingPlans, emailPlans, carePlans } from '../data/pricing';
---
<BaseLayout title="Services — SiteGenius" description="Web design, hosting, email, and website care plans for NZ businesses.">
  <section class="pt-32 pb-16 grid-bg">
    <div class="container-custom">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4 animate-slide-up">What We <span class="gradient-text">Do</span></h1>
      <p class="text-xl text-muted-200 max-w-2xl animate-slide-up" style="animation-delay:0.1s">Everything you need to get your business online and keep it running smoothly.</p>
    </div>
  </section>

  <!-- Services Loop -->
  <section class="section-padding">
    <div class="container-custom">
      <div class="space-y-20">
        {services.map((service, index) => (
          <div class={`grid lg:grid-cols-2 gap-12 items-center ${index % 2 !== 0 ? 'lg:flex-row-reverse' : ''}`}>
            <div class={`animate-on-scroll ${index % 2 !== 0 ? 'lg:order-2' : ''}`}>
              <div class={`w-14 h-14 rounded-xl bg-${service.color}/10 flex items-center justify-center mb-6`}>
                <svg class={`w-7 h-7 text-${service.color}`} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={service.icon} />
                </svg>
              </div>
              <h2 class="text-3xl font-heading font-bold mb-4">{service.title}</h2>
              <p class="text-muted-200 leading-relaxed mb-6">{service.description}</p>
              
              {index === 0 && (
                <div class="glass rounded-xl p-4 inline-flex items-center gap-3 mb-6">
                  <svg class="w-6 h-6 text-amber-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
                  </svg>
                  <p class="text-sm text-muted-200"><strong class="text-muted-100">Got an idea?</strong> If you have any idea about website or app let's talk, we can definitely work around for you.</p>
                </div>
              )}
            </div>
            
            <div class={`grid grid-cols-2 gap-4 animate-on-scroll ${index % 2 !== 0 ? 'lg:order-1' : ''}`}>
              {service.features.map(f => (
                <div class="glass rounded-lg p-4 flex items-start gap-3 glass-hover">
                  <svg class="w-5 h-5 text-neon-cyan flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-sm text-muted-200 leading-tight">{f}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <CTABanner
    title="Not sure what you need?"
    description="We'll figure it out together."
    href="/contact"
    label="Book a Free Chat"
  />
</BaseLayout>
