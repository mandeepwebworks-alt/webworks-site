---
import BaseLayout from '../layouts/BaseLayout.astro';
import PortfolioCard from '../components/ui/PortfolioCard.astro';
import Button from '../components/ui/Button.astro';
import { projects, categories } from '../data/portfolio';
---
<BaseLayout title="Portfolio — SiteGenius" description="See websites we've built for NZ businesses.">
  <section class="pt-32 pb-16 grid-bg">
    <div class="container-custom">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4 animate-slide-up">Our <span class="gradient-text">Work</span></h1>
      <p class="text-xl text-muted-200 max-w-2xl animate-slide-up" style="animation-delay:0.1s">A showcase of websites we've built for businesses across NZ, Australia, Canada, and beyond.</p>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-custom">
      <!-- Filter -->
      <div class="flex flex-wrap gap-3 mb-12 animate-on-scroll">
        {categories.map((cat, i) => (
          <button data-filter={cat} class={`portfolio-filter px-4 py-2 rounded-full text-sm font-medium transition-all ${i === 0 ? 'bg-neon-cyan text-space-900' : 'bg-space-700/50 text-muted-200 hover:bg-space-600/50 hover:text-muted-100'}`}>{cat}</button>
        ))}
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" id="portfolio-grid">
        {projects.map((project) => (
          <div class="animate-on-scroll portfolio-item" data-category={project.category}>
            <PortfolioCard {...project} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Portfolio Modal — z-[100] beats the fixed site header (z-50) -->
  <div id="portfolio-modal" class="fixed inset-0 z-[100] hidden flex-col bg-space-900">

    <!-- Top bar -->
    <div class="flex items-center gap-3 px-4 py-3 border-b border-white/[0.08] bg-space-800/95 backdrop-blur-sm shrink-0">
      <button id="modal-back" class="flex items-center gap-2 text-sm font-semibold text-muted-200 hover:text-neon-cyan transition-colors shrink-0">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        <span class="hidden sm:inline">Back to Portfolio</span>
      </button>
      <div class="flex-1 min-w-0 flex items-center gap-2">
        <span id="modal-category" class="shrink-0 text-xs font-medium text-neon-cyan bg-neon-cyan/10 px-2.5 py-1 rounded-full"></span>
        <span id="modal-title-bar" class="text-sm font-semibold text-muted-100 truncate"></span>
      </div>
      <a id="modal-open-btn" href="#" target="_blank" rel="noopener noreferrer"
        class="hidden shrink-0 items-center gap-1.5 text-xs font-semibold px-3 py-2 rounded-lg bg-neon-cyan text-space-900 hover:shadow-[0_0_16px_rgba(0,229,255,0.4)] transition-all">
        Open in new tab
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      </a>
    </div>

    <!-- Browser address bar -->
    <div id="modal-addressbar" class="hidden items-center gap-2 px-4 py-2 bg-space-700/60 border-b border-white/[0.06] shrink-0">
      <div class="flex items-center gap-1.5 shrink-0">
        <span class="h-2.5 w-2.5 rounded-full bg-[#FF5F57]"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-[#FEBC2E]"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-[#28C840]"></span>
      </div>
      <div class="flex-1 flex items-center gap-2 bg-space-900/60 rounded-lg px-3 py-1.5 min-w-0">
        <svg class="w-3 h-3 text-emerald-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
        <span id="modal-address-url" class="text-xs font-mono text-muted-200 truncate"></span>
      </div>
    </div>

    <!-- Iframe area -->
    <div class="relative flex-1 min-h-0 bg-white">
      <!-- Loading spinner -->
      <div id="modal-loader" class="absolute inset-0 flex flex-col items-center justify-center bg-space-900 z-10 gap-4">
        <div class="h-10 w-10 rounded-full border-2 border-neon-cyan/20 border-t-neon-cyan animate-spin"></div>
        <p class="text-sm text-muted-300">Loading site…</p>
      </div>
      <!-- Blocked fallback -->
      <div id="modal-blocked" class="hidden absolute inset-0 flex flex-col items-center justify-center bg-space-900 z-10 gap-5 px-6 text-center">
        <div class="h-14 w-14 rounded-2xl bg-white/[0.04] border border-white/[0.08] flex items-center justify-center">
          <svg class="w-7 h-7 text-muted-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5V6.75a4.5 4.5 0 119 0v3.75M3.75 21.75h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H3.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
        </div>
        <div>
          <p class="text-base font-semibold text-muted-100 mb-1">This site can't be embedded</p>
          <p class="text-sm text-muted-300 max-w-sm">The site's security settings prevent it from loading inside another page. Open it in a new tab to explore it fully.</p>
        </div>
        <a id="modal-blocked-btn" href="#" target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-2 text-sm font-semibold px-5 py-3 rounded-xl bg-neon-cyan text-space-900 hover:shadow-[0_0_20px_rgba(0,229,255,0.4)] transition-all">
          Open in new tab
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>
      <iframe id="modal-iframe" src="" class="w-full h-full border-0" title="Site preview"
        sandbox="allow-scripts allow-same-origin allow-forms allow-popups allow-popups-to-escape-sandbox"></iframe>
    </div>
  </div>

  <section class="section-padding bg-space-800/50">
    <div class="container-custom text-center">
      <h2 class="text-3xl font-heading font-bold mb-4 animate-on-scroll">Want your business <span class="gradient-text">here?</span></h2>
      <p class="text-xl text-muted-200 mb-8 animate-on-scroll">Let's make it happen.</p>
      <div class="animate-on-scroll"><Button href="/get-a-quote" class="text-lg">Start Your Project</Button></div>
    </div>
  </section>
</BaseLayout>

<script>
  // ── Portfolio Modal ──
  const modal        = document.getElementById('portfolio-modal')!;
  // Move modal to <body> so it escapes the <main z-10> stacking context
  document.body.appendChild(modal);
  const backBtn      = document.getElementById('modal-back')!;
  const modalCat     = document.getElementById('modal-category')!;
  const modalTitleBar = document.getElementById('modal-title-bar')!;
  const modalOpenBtn   = document.getElementById('modal-open-btn') as HTMLAnchorElement;
  const modalAddressBar = document.getElementById('modal-addressbar')!;
  const modalAddressUrl = document.getElementById('modal-address-url')!;
  const modalIframe    = document.getElementById('modal-iframe') as HTMLIFrameElement;
  const modalLoader  = document.getElementById('modal-loader')!;
  const modalBlocked = document.getElementById('modal-blocked')!;
  const modalBlockedBtn = document.getElementById('modal-blocked-btn') as HTMLAnchorElement;

  let blockedTimer: ReturnType<typeof setTimeout> | null = null;

  function showLoader() {
    modalLoader.classList.remove('hidden');
    modalBlocked.classList.add('hidden');
  }

  function onIframeLoad() {
    // After load fires, try accessing contentDocument — cross-origin throws but that means it loaded fine.
    // If the iframe was blocked by X-Frame-Options, the browser navigates it to about:blank or an error page.
    if (blockedTimer) clearTimeout(blockedTimer);
    try {
      const loc = modalIframe.contentWindow?.location.href;
      // about:blank means the browser blocked it
      if (loc === 'about:blank') {
        modalLoader.classList.add('hidden');
        modalBlocked.classList.remove('hidden');
      } else {
        modalLoader.classList.add('hidden');
      }
    } catch {
      // SecurityError = cross-origin but loaded fine
      modalLoader.classList.add('hidden');
    }
  }

  function openModal(data: { title: string; category: string; description: string; tags: string[]; url?: string; isExternal?: boolean }) {
    modalCat.textContent = data.category;
    modalTitleBar.textContent = data.title;

    // Open-in-new-tab button + address bar (external sites only)
    if (data.isExternal && data.url) {
      modalOpenBtn.href = data.url;
      modalBlockedBtn.href = data.url;
      modalOpenBtn.classList.remove('hidden');
      modalOpenBtn.classList.add('inline-flex');
      modalAddressUrl.textContent = data.url.replace(/^https?:\/\//, '');
      modalAddressBar.classList.remove('hidden');
      modalAddressBar.classList.add('flex');
    } else {
      modalOpenBtn.classList.add('hidden');
      modalOpenBtn.classList.remove('inline-flex');
      modalAddressBar.classList.add('hidden');
      modalAddressBar.classList.remove('flex');
    }

    // Load iframe (all sites — external and internal demos)
    showLoader();
    modalIframe.src = data.url || '';

    // Fallback: if load event never fires within 12s, assume blocked
    blockedTimer = setTimeout(() => {
      modalLoader.classList.add('hidden');
      modalBlocked.classList.remove('hidden');
    }, 12000);

    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (blockedTimer) clearTimeout(blockedTimer);
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
    modalIframe.src = '';
    modalLoader.classList.remove('hidden');
    modalBlocked.classList.add('hidden');
    modalAddressBar.classList.add('hidden');
    modalAddressBar.classList.remove('flex');
  }

  modalIframe.addEventListener('load', onIframeLoad);

  document.querySelectorAll('.portfolio-card').forEach(card => {
    card.addEventListener('click', () => {
      const data = JSON.parse((card as HTMLElement).dataset.project || '{}');
      openModal(data);
    });
  });

  backBtn.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  // ── Filters ──
  const filters = document.querySelectorAll('.portfolio-filter');
  const items = document.querySelectorAll('.portfolio-item');

  filters.forEach((button) => {
    button.addEventListener('click', () => {
      const filter = button.getAttribute('data-filter');
      filters.forEach((node, index) => {
        node.classList.toggle('bg-neon-cyan', node === button);
        node.classList.toggle('text-space-900', node === button);
        if (node !== button && index !== 0) {
          node.classList.add('bg-space-700/50', 'text-muted-200');
        }
      });

      items.forEach((item) => {
        const matches = filter === 'All' || item.getAttribute('data-category') === filter;
        item.classList.toggle('hidden', !matches);
      });
    });
  });
</script>
