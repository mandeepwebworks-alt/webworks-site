<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kiwi Legal Advisors — Demo | SiteGenius</title>
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet" />
  <style>
    *{margin:0;padding:0;box-sizing:border-box}body{font-family:'Source Sans 3',sans-serif;color:#c8cad0;background:#0c1222}h1,h2,h3{font-family:'Libre Baskerville',serif}
    .demo-bar{background:linear-gradient(90deg,#b8860b,#daa520);color:#0c1222;text-align:center;padding:10px;font-size:13px;font-weight:600;position:fixed;top:0;left:0;right:0;z-index:999}.demo-bar a{color:#0c1222;text-decoration:underline}
    .hero{min-height:100vh;display:flex;align-items:center;padding-top:50px;background:linear-gradient(160deg,#0c1222 0%,#141e38 50%,#0c1222 100%);position:relative;border-bottom:3px solid #b8860b}
    .hero-inner{max-width:1200px;margin:0 auto;padding:0 24px;display:grid;grid-template-columns:1.3fr 1fr;gap:60px;align-items:center}
    .hero h1{font-size:3.2rem;line-height:1.25;color:#fff;font-weight:700}.hero h1 span{color:#daa520}
    .hero p{margin-top:16px;font-size:1.05rem;color:#8690a8;line-height:1.7}
    .hero-btns{display:flex;gap:12px;margin-top:28px}
    .btn-gold{padding:16px 36px;background:#b8860b;color:#fff;text-decoration:none;font-weight:700;transition:.3s;letter-spacing:.5px}.btn-gold:hover{background:#daa520}
    .btn-dark{padding:16px 36px;border:1px solid #2a3552;color:#8690a8;text-decoration:none;font-weight:600;transition:.3s}.btn-dark:hover{border-color:#daa520;color:#daa520}
    .hero-right{border:1px solid #1e2d4d;padding:36px;background:rgba(20,30,56,.5)}
    .hero-right h3{font-size:1rem;color:#daa520;margin-bottom:16px;text-transform:uppercase;letter-spacing:2px;font-family:'Source Sans 3',sans-serif}
    .area{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid #1e2d4d;font-size:.95rem;color:#c8cad0}
    .area:last-child{border:none}
    .areas{padding:100px 24px;max-width:1200px;margin:0 auto}
    .areas h2{text-align:center;font-size:2.2rem;color:#fff;margin-bottom:12px}.areas h2 span{color:#daa520}
    .areas>p{text-align:center;color:#8690a8;margin-bottom:48px}
    .area-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
    .area-card{background:#141e38;border:1px solid #1e2d4d;padding:32px;transition:.3s}.area-card:hover{border-color:#b8860b;box-shadow:0 0 30px rgba(184,134,11,.08)}
    .area-card .icon{font-size:2rem;margin-bottom:12px}.area-card h3{font-size:1.1rem;color:#fff;margin-bottom:8px;font-family:'Source Sans 3',sans-serif;font-weight:700}.area-card p{font-size:.85rem;color:#8690a8;line-height:1.6}
    .team{padding:80px 24px;background:#0f1830;border-top:1px solid #1e2d4d;border-bottom:1px solid #1e2d4d}
    .team-inner{max-width:900px;margin:0 auto;text-align:center}
    .team h2{font-size:2rem;color:#fff;margin-bottom:36px}.team h2 span{color:#daa520}
    .team-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
    .person{padding:28px;background:#141e38;border:1px solid #1e2d4d;text-align:center}
    .person .avatar{width:60px;height:60px;background:#1e2d4d;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;font-size:1.5rem;color:#daa520}
    .person h3{font-size:1rem;color:#fff;font-family:'Source Sans 3',sans-serif;font-weight:700}.person .role{color:#daa520;font-size:.8rem;font-weight:600}
    .cta{background:linear-gradient(135deg,#141e38,#0c1222);padding:80px 24px;text-align:center;border-top:3px solid #b8860b}
    .cta h2{font-size:2.2rem;color:#fff;margin-bottom:12px}.cta p{color:#8690a8;margin-bottom:24px}
    @media(max-width:768px){.hero-inner{grid-template-columns:1fr}.hero-right{display:none}.hero h1{font-size:2.2rem}.area-grid,.team-grid{grid-template-columns:1fr}}
  </style>
</head>
<body>
  <div class="demo-bar">⚖️ Demo by <a href="/">SiteGenius</a> — <a href="/get-a-quote">Get yours today</a></div>
  <section class="hero"><div class="hero-inner"><div><h1>Expert Legal<br><span>Advice You Can Trust</span></h1><p>Experienced NZ lawyers for property, business, family, and immigration law. Straightforward advice without the jargon.</p><div class="hero-btns"><a href="/get-a-quote" class="btn-gold">Book Consultation</a><a href="#areas" class="btn-dark">Practice Areas</a></div></div><div class="hero-right"><h3>Practice Areas</h3><div class="area">🏠 Property & Conveyancing</div><div class="area">💼 Business Law</div><div class="area">👨‍👩‍👧 Family Law</div><div class="area">✈️ Immigration</div><div class="area">📋 Employment Law</div><div class="area">📜 Wills & Estates</div></div></div></section>
  <section class="areas" id="areas"><h2>How We <span>Help</span></h2><p>Trusted legal expertise across all major practice areas.</p><div class="area-grid">
    <div class="area-card"><div class="icon">🏠</div><h3>Property</h3><p>Buying, selling, and all residential and commercial transactions.</p></div>
    <div class="area-card"><div class="icon">💼</div><h3>Business Law</h3><p>Company formation, contracts, and shareholder agreements.</p></div>
    <div class="area-card"><div class="icon">👨‍👩‍👧</div><h3>Family Law</h3><p>Separation, custody, and relationship property.</p></div>
    <div class="area-card"><div class="icon">✈️</div><h3>Immigration</h3><p>Visa applications, residency, and appeal support.</p></div>
    <div class="area-card"><div class="icon">📋</div><h3>Employment</h3><p>Agreements, disputes, and personal grievances.</p></div>
    <div class="area-card"><div class="icon">📜</div><h3>Wills & Estates</h3><p>Will drafting, trusts, and enduring powers of attorney.</p></div>
  </div></section>
  <section class="team"><div class="team-inner"><h2>Our <span>Team</span></h2><div class="team-grid">
    <div class="person"><div class="avatar">JC</div><h3>James Chen</h3><div class="role">Senior Partner</div></div>
    <div class="person"><div class="avatar">SW</div><h3>Sarah Williams</h3><div class="role">Associate</div></div>
    <div class="person"><div class="avatar">DP</div><h3>David Patel</h3><div class="role">Associate</div></div>
  </div></div></section>
  <section class="cta"><h2>Need Legal Advice?</h2><p>Book a free 30-minute initial consultation. No obligation.</p><a href="/get-a-quote" class="btn-gold">Book Free Consultation →</a></section>
</body>
</html>
