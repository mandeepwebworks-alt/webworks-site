---
---
<section class="section-padding relative overflow-hidden">
  <!-- Ambient background blobs -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute left-1/4 top-0 h-[400px] w-[400px] rounded-full bg-neon-cyan/[0.05] blur-[100px]"></div>
    <div class="absolute right-1/4 bottom-0 h-[400px] w-[400px] rounded-full bg-neon-purple/[0.05] blur-[100px]"></div>
    <div class="absolute left-1/2 top-1/2 h-[300px] w-[300px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-amber-400/[0.04] blur-[80px]"></div>
  </div>

  <div class="container-custom relative">

    <!-- Centred headline -->
    <div class="text-center mb-12 animate-on-scroll">
      <div class="inline-flex items-center gap-2 rounded-full border border-amber-400/20 bg-amber-400/[0.06] px-4 py-1.5 mb-6">
        <svg class="h-4 w-4 text-amber-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/></svg>
        <span class="text-xs font-heading font-semibold text-amber-300 uppercase tracking-wider">Got an Idea?</span>
      </div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.1] mb-4">
        Got a website idea?<br/>
        <span class="gradient-text">Type it right here.</span>
      </h2>
      <p class="text-lg text-muted-200 max-w-xl mx-auto">
        No forms, no phone calls. Just type what you're thinking and we'll take it from there.
      </p>
    </div>

    <!-- The big interactive input -->
    <div class="max-w-3xl mx-auto animate-on-scroll">

      <!-- Input card — default state -->
      <div id="idea-card" class="relative group">
        <!-- Outer animated glow ring -->
        <div id="idea-ring" class="absolute -inset-px rounded-2xl opacity-0 transition-opacity duration-500 pointer-events-none" style="background: linear-gradient(135deg, rgba(0,229,255,0.4), rgba(139,92,246,0.4)); border-radius: inherit;"></div>
        <!-- Card body -->
        <div class="relative rounded-2xl border border-white/[0.08] bg-space-800/70 backdrop-blur-sm overflow-hidden">
          <!-- Top accent bar (animates in) -->
          <div id="idea-bar" class="h-0.5 w-0 bg-gradient-to-r from-neon-cyan via-neon-purple to-neon-cyan transition-all duration-700 ease-out"></div>

          <div class="px-6 pt-6 pb-5">
            <!-- Label row -->
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-2">
                <div id="idea-dot" class="h-2 w-2 rounded-full bg-white/20 transition-all duration-500"></div>
                <span id="idea-label" class="text-xs font-mono text-muted-300 uppercase tracking-widest transition-all duration-300">Your idea</span>
              </div>
              <span id="idea-chars" class="text-xs font-mono text-muted-300 opacity-0 transition-opacity duration-300">0 / 120</span>
            </div>

            <!-- Input row -->
            <div class="flex items-center gap-4">
              <input
                id="idea-input"
                type="text"
                placeholder="I need a website for my plumbing business in Auckland..."
                autocomplete="off"
                maxlength="120"
                class="flex-1 bg-transparent border-none outline-none text-lg md:text-xl font-heading font-semibold text-muted-100 placeholder:text-muted-300 placeholder:font-normal p-0 focus:ring-0 min-w-0"
              />
              <button id="idea-send" class="hidden shrink-0 items-center gap-2 rounded-xl bg-neon-cyan px-5 py-3 text-sm font-bold text-space-900 transition-all duration-200 hover:shadow-[0_0_24px_rgba(0,229,255,0.4)] active:scale-95">
                Send
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/></svg>
              </button>
            </div>

            <!-- Bottom hint row -->
            <div class="mt-4 flex items-center gap-2">
              <svg id="hint-icon" class="h-3.5 w-3.5 text-muted-300 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"/></svg>
              <p id="idea-hint" class="text-xs text-muted-300 transition-all duration-300">Press Enter ↵ or click Send — your idea will be saved to your quote form</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Success state -->
      <div id="idea-success" class="hidden">
        <div class="relative rounded-2xl border border-emerald-400/30 bg-emerald-400/[0.06] overflow-hidden">
          <div class="h-0.5 bg-gradient-to-r from-emerald-400/0 via-emerald-400 to-emerald-400/0"></div>
          <div class="px-6 py-6 flex items-center gap-5">
            <div class="h-12 w-12 rounded-xl bg-emerald-400/10 border border-emerald-400/20 flex items-center justify-center shrink-0">
              <svg class="h-6 w-6 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-bold text-emerald-400 mb-0.5">Idea saved — opening your quote form!</p>
              <p id="idea-preview" class="text-muted-200 font-heading font-semibold truncate"></p>
            </div>
            <div class="flex items-center gap-2 text-xs text-muted-300 shrink-0">
              <svg class="h-4 w-4 animate-spin text-neon-cyan" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>
              Redirecting...
            </div>
          </div>
        </div>
      </div>

      <!-- Trust nudge below input -->
      <div id="idea-trust" class="flex flex-wrap items-center justify-center gap-6 mt-6 opacity-0 transition-opacity duration-500">
        <span class="flex items-center gap-1.5 text-xs text-muted-300">
          <svg class="h-3.5 w-3.5 text-neon-cyan" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          No commitment needed
        </span>
        <span class="flex items-center gap-1.5 text-xs text-muted-300">
          <svg class="h-3.5 w-3.5 text-neon-cyan" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          We reply within 24hrs
        </span>
        <span class="flex items-center gap-1.5 text-xs text-muted-300">
          <svg class="h-3.5 w-3.5 text-neon-cyan" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Free quote, no hidden costs
        </span>
      </div>
    </div>

    <!-- Or buttons below -->
    <div class="text-center mt-10 animate-on-scroll">
      <p class="text-sm text-muted-300 mb-4">or</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/get-a-quote" class="btn-primary !px-8 !py-3 rounded-full">Fill Out a Full Quote</a>
        <a href="/contact" class="px-8 py-3 rounded-full border border-white/[0.08] text-muted-100 hover:bg-white/[0.04] transition-all text-sm font-medium">Book a Free Chat</a>
      </div>
    </div>

  </div>
</section>

<script>
  const card = document.getElementById('idea-card');
  const ring = document.getElementById('idea-ring');
  const bar = document.getElementById('idea-bar');
  const dot = document.getElementById('idea-dot');
  const label = document.getElementById('idea-label');
  const chars = document.getElementById('idea-chars');
  const hintEl = document.getElementById('idea-hint');
  const trust = document.getElementById('idea-trust');
  const input = document.getElementById('idea-input') as HTMLInputElement;
  const sendBtn = document.getElementById('idea-send');
  const successEl = document.getElementById('idea-success');
  const ideaPreview = document.getElementById('idea-preview');

  function activate() {
    ring?.style.setProperty('opacity', '1');
    if (bar) bar.style.width = '100%';
    if (dot) { dot.classList.remove('bg-white/20'); dot.classList.add('bg-neon-cyan', 'shadow-[0_0_8px_rgba(0,229,255,0.6)]'); }
    if (label) { label.classList.remove('text-muted-300'); label.classList.add('text-neon-cyan'); }
    if (chars) chars.style.opacity = '1';
    if (trust) trust.style.opacity = '1';
    if (hintEl) hintEl.textContent = "Hit Enter ↵ or click Send — we'll pre-fill your quote with this";
  }

  function deactivate() {
    if (input?.value.trim()) return;
    ring?.style.setProperty('opacity', '0');
    if (bar) bar.style.width = '0';
    if (dot) { dot.classList.add('bg-white/20'); dot.classList.remove('bg-neon-cyan', 'shadow-[0_0_8px_rgba(0,229,255,0.6)]'); }
    if (label) { label.classList.add('text-muted-300'); label.classList.remove('text-neon-cyan'); }
    if (chars) chars.style.opacity = '0';
    if (trust) trust.style.opacity = '0';
    sendBtn?.classList.add('hidden');
    sendBtn?.classList.remove('inline-flex');
    if (hintEl) hintEl.textContent = "Press Enter ↵ or click Send — your idea will be saved to your quote form";
  }

  function submitIdea() {
    const idea = input?.value.trim();
    if (!idea) return;
    if (card) card.classList.add('hidden');
    if (successEl) successEl.classList.remove('hidden');
    if (ideaPreview) ideaPreview.textContent = `"${idea}"`;
    setTimeout(() => {
      window.location.href = `/get-a-quote?idea=${encodeURIComponent(idea)}`;
    }, 1600);
  }

  input?.addEventListener('focus', activate);
  input?.addEventListener('blur', () => setTimeout(deactivate, 150));
  input?.addEventListener('input', () => {
    const len = input.value.length;
    if (chars) chars.textContent = `${len} / 120`;
    if (len > 0) {
      activate();
      sendBtn?.classList.remove('hidden');
      sendBtn?.classList.add('inline-flex');
    } else {
      sendBtn?.classList.add('hidden');
      sendBtn?.classList.remove('inline-flex');
    }
  });
  input?.addEventListener('keydown', (e) => { if (e.key === 'Enter') submitIdea(); });
  sendBtn?.addEventListener('click', submitIdea);
</script>
