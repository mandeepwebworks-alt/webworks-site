---
import PricingCard from '../ui/PricingCard.astro';
import Button from '../ui/Button.astro';
import { websitePackages } from '../../data/pricing';
---
<section class="section-padding">
  <div class="container-custom">
    <div class="mb-16 animate-on-scroll">
      <p class="section-label">Pricing</p>
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <h2 class="text-4xl md:text-5xl lg:text-6xl max-w-lg">
          Transparent pricing<span class="text-neon-cyan">.</span> <span class="gradient-text">One-off fee</span>
        </h2>
        <p class="text-muted-200 max-w-sm">Pay once, own your website forever. No monthly lock-in, no surprises.</p>
      </div>
    </div>
    <div class="mx-auto grid max-w-6xl gap-6 md:grid-cols-3 stagger-children">
      {websitePackages.map((plan) => (
        <div class="animate-on-scroll">
          <PricingCard {...plan} features={plan.features.slice(0, 4)} />
        </div>
      ))}
    </div>
    <div class="mt-10 text-center animate-on-scroll">
      <p class="mb-5 text-sm text-muted-300">All prices excl. GST. Hosting from $25/mo extra.</p>
      <Button href="/pricing" variant="secondary">See All Pricing Options</Button>
    </div>
  </div>
</section>
