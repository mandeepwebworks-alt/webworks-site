---
import Button from '../ui/Button.astro';

const industries = [
  {
    id: 'cafe',
    label: '☕ Café',
    word: 'cafes',
    url: 'thedailygrind.co.nz',
    accent: '#f59e0b',
    badge: '● Open Now',
    badgeColor: '#10b981',
    headline: 'Great Coffee,',
    sub: 'Warm Vibes',
    desc: 'Freshly roasted beans, cabinet food & free WiFi. Your neighbourhood favourite.',
    cta: 'View Menu',
    ctaBg: '#f59e0b',
    ctaText: '#1a1a2e',
    tags: ['Online Orders', 'Table Bookings', 'Loyalty Points'],
    navLinks: ['Menu', 'About', 'Events', 'Find Us'],
    gradFrom: '#78350f', gradTo: '#1c1008',
  },
  {
    id: 'tradie',
    label: '🔧 Tradie',
    word: 'tradies',
    url: 'proflowplumbing.co.nz',
    accent: '#f97316',
    badge: '⚡ 24/7 Emergency',
    badgeColor: '#f97316',
    headline: 'Your Local',
    sub: 'Plumber',
    desc: 'Fast, reliable plumbing for homes & businesses. Licensed & insured.',
    cta: 'Get a Quote',
    ctaBg: '#f97316',
    ctaText: '#fff',
    tags: ['Residential', 'Commercial', 'Gas Fitting'],
    navLinks: ['Services', 'About', 'Gallery', 'Contact'],
    gradFrom: '#1e293b', gradTo: '#0f172a',
  },
  {
    id: 'salon',
    label: '💅 Salon',
    word: 'salons',
    url: 'luxebeauty.co.nz',
    accent: '#ec4899',
    badge: '★ 5.0 Rated',
    badgeColor: '#f472b6',
    headline: 'Beauty',
    sub: 'Redefined',
    desc: 'Hair, nails, facials & more. Book your appointment online, any time.',
    cta: 'Book Now',
    ctaBg: '#ec4899',
    ctaText: '#fff',
    tags: ['Hair & Colour', 'Nail Art', 'Facials'],
    navLinks: ['Services', 'Gallery', 'Team', 'Book'],
    gradFrom: '#831843', gradTo: '#1a0a12',
  },
  {
    id: 'retail',
    label: '🛍 Retail',
    word: 'retailers',
    url: 'shopkiwi.co.nz',
    accent: '#8b5cf6',
    badge: '🚚 Free Shipping $80+',
    badgeColor: '#a78bfa',
    headline: 'Shop the',
    sub: 'Collection',
    desc: 'Curated homewares, gifts & lifestyle. Delivered fast.',
    cta: 'Shop Now',
    ctaBg: '#8b5cf6',
    ctaText: '#fff',
    tags: ['Homewares', 'Gifts', 'New Arrivals'],
    navLinks: ['Shop', 'Collections', 'Sale', 'About'],
    gradFrom: '#3b0764', gradTo: '#0d0118',
  },
  {
    id: 'startup',
    label: '🚀 Startup',
    word: 'startups',
    url: 'launchpad.io',
    accent: '#06b6d4',
    badge: '🚀 Now Live',
    badgeColor: '#22d3ee',
    headline: 'The Future',
    sub: 'Starts Here',
    desc: "We're changing how businesses manage their workflows. Join 2,000+ users.",
    cta: 'Get Early Access',
    ctaBg: '#06b6d4',
    ctaText: '#000',
    tags: ['SaaS Platform', 'API Access', 'Free Trial'],
    navLinks: ['Product', 'Pricing', 'Docs', 'Login'],
    gradFrom: '#0c4a6e', gradTo: '#040d18',
  },
];
---

<section class="relative min-h-screen overflow-hidden">
  <div class="pointer-events-none absolute inset-0">
    <div class="mesh-blob -left-32 top-16 h-[500px] w-[500px] bg-neon-cyan/[0.07]"></div>
    <div class="mesh-blob -right-32 bottom-20 h-[600px] w-[600px] bg-neon-purple/[0.07] [animation-delay:2s]"></div>
    <div class="absolute inset-0 grid-bg opacity-40"></div>
  </div>

  <div class="container-custom relative z-10 flex min-h-screen items-center pt-24 pb-16">
    <div class="grid w-full items-center gap-12 lg:gap-16 lg:grid-cols-[1fr_440px]">

      <!-- Left: Copy -->
      <div>
        <div class="inline-flex items-center gap-2 rounded-full border border-white/[0.06] bg-white/[0.03] px-4 py-2 backdrop-blur-sm animate-fade-in">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400"></span>
          </span>
          <span class="text-xs font-medium tracking-wide text-muted-200">Available for new projects</span>
        </div>

        <h1 class="mt-8 animate-slide-up">
          <span class="block text-5xl font-bold leading-[1.1] text-muted-100 md:text-7xl lg:text-[5.2rem]">Websites That Work</span>
          <span class="mt-2 block text-5xl font-bold leading-[1.1] gradient-text md:text-7xl lg:text-[5.2rem]">As Hard As You Do</span>
        </h1>

        <!-- Typed line — word syncs with active industry -->
        <p class="mt-8 max-w-lg text-lg leading-relaxed text-muted-200 animate-slide-up [animation-delay:150ms]">
          We build websites for <span id="typed-text" class="text-neon-cyan font-medium"></span><span class="inline-block w-[2px] h-5 bg-neon-cyan/80 align-middle animate-pulse ml-0.5"></span>
        </p>

        <p class="mt-6 max-w-lg text-lg leading-relaxed text-muted-300 animate-slide-up [animation-delay:200ms]">
          Professional, lightning-fast websites for businesses of all shapes. No jargon. No nonsense. Just results.
        </p>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row animate-slide-up [animation-delay:300ms]">
          <Button href="/get-a-quote">Get a Free Quote</Button>
          <Button href="/portfolio" variant="secondary">See Our Work</Button>
        </div>

        <!-- ── Mobile industry strip (lg:hidden) ── -->
        <div class="mt-8 lg:hidden animate-slide-up [animation-delay:400ms]">
          <!-- Mobile tabs -->
          <div class="flex gap-2 overflow-x-auto pb-1 no-scrollbar" id="mobile-tabs">
            {industries.map((ind, i) => (
              <button
                data-industry={ind.id}
                class={`industry-tab shrink-0 text-xs font-semibold px-3 py-1.5 rounded-full border transition-all duration-200 ${i === 0 ? 'active' : 'border-white/[0.08] text-muted-300'}`}
                style={i === 0 ? `border-color:${ind.accent}40;color:${ind.accent};background:${ind.accent}18;` : ''}
              >
                {ind.label}
              </button>
            ))}
          </div>

          <!-- Mobile slim panels -->
          <div class="relative mt-3 rounded-xl overflow-hidden" style="height:118px;">
            {industries.map((ind, i) => (
              <div
                id={`mobile-panel-${ind.id}`}
                class={`industry-panel-mobile absolute inset-0 transition-all duration-200 ease-out ${i === 0 ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-2 pointer-events-none'}`}
                style={`background:linear-gradient(135deg, ${ind.gradFrom}, ${ind.gradTo});`}
              >
                <div class="flex h-full flex-col justify-between px-4 py-3">
                  <div class="flex items-start justify-between gap-2">
                    <div>
                      <p class="text-base font-black text-white leading-tight">
                        {ind.headline} <span style={`color:${ind.accent}`}>{ind.sub}</span>
                      </p>
                    </div>
                    <span class="shrink-0 text-[10px] font-semibold px-2 py-0.5 rounded-full" style={`background:${ind.badgeColor}25;color:${ind.badgeColor};`}>
                      {ind.badge}
                    </span>
                  </div>
                  <div class="flex items-center justify-between">
                    <div class="flex gap-1.5">
                      {ind.tags.slice(0,3).map(tag => (
                        <span class="text-[10px] font-medium px-2 py-0.5 rounded-md text-white/60" style={`background:${ind.accent}18;`}>{tag}</span>
                      ))}
                    </div>
                    <span class="text-[10px] font-bold px-2.5 py-1 rounded-lg" style={`background:${ind.ctaBg};color:${ind.ctaText};`}>{ind.cta}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
        <!-- end mobile strip -->
      </div>

      <!-- Right: Desktop industry previewer (lg only) -->
      <div class="hidden lg:block animate-slide-up [animation-delay:200ms]">
        <!-- Desktop tabs -->
        <div class="flex flex-wrap gap-2 mb-3" id="desktop-tabs">
          {industries.map((ind, i) => (
            <button
              data-industry={ind.id}
              class={`industry-tab text-xs font-semibold px-3 py-1.5 rounded-full border transition-all duration-200 ${i === 0 ? 'active' : 'border-white/[0.08] text-muted-300 hover:text-muted-100 hover:border-white/20'}`}
              style={i === 0 ? `border-color:${ind.accent}40;color:${ind.accent};background:${ind.accent}18;` : ''}
            >
              {ind.label}
            </button>
          ))}
        </div>

        <!-- Browser chrome -->
        <div class="rounded-2xl overflow-hidden border border-white/[0.08] shadow-2xl">
          <!-- Top bar -->
          <div class="flex items-center gap-2 bg-space-800/80 backdrop-blur-sm px-4 py-2.5 border-b border-white/[0.06]">
            <span class="h-2.5 w-2.5 rounded-full bg-[#FF5F57]"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#FEBC2E]"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#28C840]"></span>
            <div class="ml-2 flex-1 bg-space-700/60 rounded-md px-3 py-1 flex items-center gap-2">
              <svg class="w-3 h-3 text-emerald-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
              <span id="previewer-url" class="text-xs font-mono text-muted-300 truncate transition-all duration-200">thedailygrind.co.nz</span>
            </div>
          </div>

          <!-- Desktop panels -->
          <div class="relative overflow-hidden" style="height:310px;">
            {industries.map((ind, i) => (
              <div
                id={`desktop-panel-${ind.id}`}
                class={`industry-panel-desktop absolute inset-0 transition-all duration-200 ease-out ${i === 0 ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-2 pointer-events-none'}`}
                style={`background:linear-gradient(160deg, ${ind.gradFrom}, ${ind.gradTo});`}
              >
                <!-- Fake nav -->
                <div class="flex items-center justify-between px-5 py-3 border-b border-white/[0.06]">
                  <span class="text-xs font-bold text-white/90 uppercase tracking-wider">{ind.url.split('.')[0]}</span>
                  <div class="flex items-center gap-4">
                    {ind.navLinks.slice(0,3).map(link => (
                      <span class="text-[10px] text-white/50">{link}</span>
                    ))}
                    <span class="text-[10px] font-semibold px-2.5 py-1 rounded-full text-white" style={`background:${ind.accent}30;`}>{ind.navLinks[3]}</span>
                  </div>
                </div>

                <!-- Content -->
                <div class="px-5 pt-5 pb-4">
                  <span class="inline-flex items-center gap-1.5 text-[10px] font-semibold px-2.5 py-1 rounded-full mb-3" style={`background:${ind.badgeColor}20;color:${ind.badgeColor};`}>
                    {ind.badge}
                  </span>
                  <h3 class="text-2xl font-black text-white leading-tight mb-1">
                    {ind.headline}<br/>
                    <span style={`color:${ind.accent}`}>{ind.sub}</span>
                  </h3>
                  <p class="text-xs text-white/50 leading-relaxed mb-4 max-w-[260px]">{ind.desc}</p>
                  <button class="text-xs font-bold px-4 py-2 rounded-lg" style={`background:${ind.ctaBg};color:${ind.ctaText};`}>
                    {ind.cta} →
                  </button>
                </div>

                <!-- Tags -->
                <div class="absolute bottom-0 left-0 right-0 px-5 py-3 border-t border-white/[0.06] flex items-center gap-2">
                  {ind.tags.map(tag => (
                    <span class="text-[10px] font-medium px-2 py-1 rounded-md text-white/60" style={`background:${ind.accent}15;`}>{tag}</span>
                  ))}
                  <span class="ml-auto text-[10px] text-white/30 font-mono">SiteGenius ✦</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <p class="text-center text-[11px] text-muted-300 mt-2.5">← Pick your industry to see what we'd build</p>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-0 right-0 flex justify-center animate-bounce pointer-events-none">
    <div class="h-10 w-6 rounded-full border border-white/10 flex items-start justify-center p-1.5">
      <div class="h-2 w-1 rounded-full bg-neon-cyan/60 animate-pulse"></div>
    </div>
  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  // ── Industry + Typed text — fully synced ──
  const tabData: Record<string, { accent: string; url: string; word: string }> = {
    cafe:    { accent: '#f59e0b', url: 'thedailygrind.co.nz',    word: 'cafes'     },
    tradie:  { accent: '#f97316', url: 'proflowplumbing.co.nz',  word: 'tradies'   },
    salon:   { accent: '#ec4899', url: 'luxebeauty.co.nz',       word: 'salons'    },
    retail:  { accent: '#8b5cf6', url: 'shopkiwi.co.nz',         word: 'retailers' },
    startup: { accent: '#06b6d4', url: 'launchpad.io',           word: 'startups'  },
  };
  const ids = Object.keys(tabData);
  let active = 'cafe';
  let typingTimer: ReturnType<typeof setTimeout> | null = null;

  // Type a word instantly (no delete — just replace)
  function typeWord(word: string) {
    const el = document.getElementById('typed-text');
    if (!el) return;
    if (typingTimer) clearTimeout(typingTimer);
    el.textContent = '';
    let i = 0;
    function next() {
      if (i <= word.length) {
        el.textContent = word.slice(0, i++);
        typingTimer = setTimeout(next, 75);
      }
    }
    next();
  }

  function switchIndustry(id: string) {
    if (id === active) return;
    const { accent, url, word } = tabData[id];

    // Swap desktop panels
    const dp = document.getElementById(`desktop-panel-${active}`);
    const dn = document.getElementById(`desktop-panel-${id}`);
    dp?.classList.replace('opacity-100', 'opacity-0'); dp?.classList.replace('translate-y-0', 'translate-y-2'); dp?.classList.add('pointer-events-none');
    dn?.classList.replace('opacity-0', 'opacity-100'); dn?.classList.replace('translate-y-2', 'translate-y-0'); dn?.classList.remove('pointer-events-none');

    // Swap mobile panels
    const mp = document.getElementById(`mobile-panel-${active}`);
    const mn = document.getElementById(`mobile-panel-${id}`);
    mp?.classList.replace('opacity-100', 'opacity-0'); mp?.classList.replace('translate-y-0', 'translate-y-2'); mp?.classList.add('pointer-events-none');
    mn?.classList.replace('opacity-0', 'opacity-100'); mn?.classList.replace('translate-y-2', 'translate-y-0'); mn?.classList.remove('pointer-events-none');

    // Update ALL matching tabs (desktop + mobile share same [data-industry])
    document.querySelectorAll<HTMLElement>(`[data-industry="${active}"]`).forEach(t => {
      t.className = t.className.replace('active', '').trim();
      t.classList.add('border-white/[0.08]', 'text-muted-300');
      t.style.cssText = '';
    });
    document.querySelectorAll<HTMLElement>(`[data-industry="${id}"]`).forEach(t => {
      t.classList.remove('border-white/[0.08]', 'text-muted-300');
      t.classList.add('active');
      t.style.cssText = `border-color:${accent}40;color:${accent};background:${accent}18;`;
    });

    // Update URL bar
    const urlEl = document.getElementById('previewer-url');
    if (urlEl) urlEl.textContent = url;

    // Sync typed text
    typeWord(word);

    active = id;
  }

  // Tab clicks — desktop + mobile
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-industry]') as HTMLElement | null;
    if (btn?.dataset.industry) {
      clearInterval(autoTimer);
      switchIndustry(btn.dataset.industry);
    }
  });

  // Auto-rotate — drives both widget + typed word in lockstep
  let autoIdx = 1;
  let autoTimer = setInterval(() => {
    switchIndustry(ids[autoIdx]);
    autoIdx = (autoIdx + 1) % ids.length;
  }, 3200);

  // Kick off first word immediately
  typeWord(tabData[active].word);
</script>
