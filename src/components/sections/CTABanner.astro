---
import Button from '../ui/Button.astro';
interface Props { title: string; description: string; href: string; label: string; }
const { title, description, href, label } = Astro.props;
---
<section class="section-padding">
  <div class="container-custom">
    <div class="relative overflow-hidden rounded-3xl border border-white/[0.06] bg-white/[0.02] px-8 py-20 text-center md:px-16">
      <!-- Ambient blobs -->
      <div class="absolute top-0 left-1/4 h-64 w-64 rounded-full bg-neon-cyan/[0.06] blur-[100px]"></div>
      <div class="absolute bottom-0 right-1/4 h-64 w-64 rounded-full bg-neon-purple/[0.06] blur-[100px]"></div>
      <!-- Top line -->
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-neon-cyan/40 to-transparent"></div>
      <div class="relative z-10">
        <h2 class="text-4xl md:text-5xl lg:text-6xl">{title}<span class="text-neon-cyan">.</span></h2>
        <p class="mx-auto mt-6 max-w-md text-lg text-muted-200">{description}</p>
        <div class="mt-10">
          <Button href={href} class="text-lg">{label}</Button>
        </div>
      </div>
    </div>
  </div>
</section>
