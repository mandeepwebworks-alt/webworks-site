---
const steps = [
  { num: '01', title: 'Chat', desc: 'Tell us about your business, your goals, and what you need. No tech jargon — just a friendly conversation.', iconPath: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z', color: 'neon-cyan' },
  { num: '02', title: 'Design', desc: "We create a custom design that matches your brand and speaks to your customers.", iconPath: 'M4.098 19.902a3.75 3.75 0 005.304 0l6.401-6.402M6.75 21A3.75 3.75 0 013 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 003.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008z', color: 'neon-purple' },
  { num: '03', title: 'Build', desc: 'We turn the design into a blazing-fast, SEO-ready website with clean code.', iconPath: 'M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5', color: 'neon-cyan' },
  { num: '04', title: 'Launch', desc: 'Your site goes live. We handle hosting, SSL, and everything technical.', iconPath: 'M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.58-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z', color: 'emerald-400' },
];
---
<section class="section-padding relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-space-800/40 via-transparent to-space-800/40"></div>
  <div class="container-custom relative">
    <div class="mb-20 animate-on-scroll">
      <p class="section-label">How it works</p>
      <h2 class="mt-4 text-4xl md:text-5xl lg:text-6xl">
        Four steps to your<br/><span class="gradient-text">new website</span>
      </h2>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4 stagger-children">
      {steps.map((step, i) => (
        <div class="animate-on-scroll group">
          <div class="relative h-full rounded-2xl border border-white/[0.04] bg-white/[0.02] p-8 transition-all duration-500 hover:border-white/[0.08] hover:bg-white/[0.04]">
            <span class="text-[4rem] font-heading font-bold leading-none text-white/[0.04] absolute top-4 right-6 transition-colors group-hover:text-neon-cyan/[0.08]">{step.num}</span>
            <div class="relative">
              <div class={`mb-6 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-${step.color}/[0.08]`}>
                <svg class={`h-6 w-6 text-${step.color}`} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={step.iconPath}/></svg>
              </div>
              <h3 class="text-xl font-heading text-muted-100">{step.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-muted-200">{step.desc}</p>
            </div>
            {i < steps.length - 1 && (
              <div class="absolute -right-3 top-1/2 hidden h-px w-6 border-t border-dashed border-white/10 lg:block"></div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
