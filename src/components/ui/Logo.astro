---
interface Props {
  className?: string;
}
const { className = "w-8 h-8" } = Astro.props;
---
<svg class={className} viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
  <g stroke-linecap="round" stroke-linejoin="round">
    <!-- Head Outline -->
    <path 
      stroke="currentColor" 
      stroke-width="4.5" 
      d="M 50 88
         C 50 84, 46 80, 46 78 
         C 40 78, 38 74, 38 70 
         C 40 68, 41 66, 39 64 
         C 35 62, 34 56, 34 52
         C 38 48, 40 44, 40 40 
         C 40 26, 48 16, 62 16 
         C 76 16, 84 28, 84 46 
         C 84 62, 74 68, 70 78 
         C 68 82, 68 85, 68 88" 
    />
    <!-- < / > Code symbol inside mind -->
    <g stroke="#d49e35" stroke-width="5.5">
      <path d="M 48 38 L 36 49 L 48 60" />
      <path d="M 58 32 L 48 66" />
      <path d="M 60 38 L 72 49 L 60 60" />
    </g>
  </g>
</svg>
