---
interface Props { name: string; price: string; period?: string; description: string; features: string[]; popular?: boolean; badge?: string; cta: string; ctaLink: string; }
const { name, price, period = '', description, features, popular = false, badge, cta, ctaLink } = Astro.props;
---
<div class={`relative flex flex-col h-full rounded-2xl border bg-white/[0.02] p-8 transition-all duration-500 hover:-translate-y-1 ${popular ? 'border-neon-cyan/20 bg-white/[0.04] shadow-[0_0_40px_rgba(0,229,255,0.06)]' : 'border-white/[0.06] hover:border-white/[0.1] hover:bg-white/[0.04]'}`}>
  {popular && (
    <div class="absolute -top-3 left-6 rounded-full bg-gradient-to-r from-neon-cyan to-neon-purple px-4 py-1">
      <span class="text-xs font-heading font-bold text-space-900">Most Popular</span>
    </div>
  )}
  <h3 class="text-lg font-heading text-muted-100">{name}</h3>
  {badge && <p class="mt-1 text-xs uppercase tracking-[0.15em] text-muted-300">{badge}</p>}
  <div class="mt-5 mb-1">
    <span class="text-4xl font-heading font-bold text-muted-100">{price}</span>
    {period && <span class="text-muted-300 text-sm ml-1">{period}</span>}
  </div>
  <p class="text-sm text-muted-200 mb-8">{description}</p>
  <ul class="flex-1 space-y-3 mb-8">
    {features.map(f => (
      <li class="flex items-start gap-3 text-sm text-muted-200">
        <svg class="w-4 h-4 text-neon-cyan flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        {f}
      </li>
    ))}
  </ul>
  <a href={ctaLink} class={`text-center rounded-xl py-3.5 px-6 text-sm font-heading font-semibold transition-all duration-300 ${popular ? 'bg-neon-cyan text-space-900 shadow-[0_0_20px_rgba(0,229,255,0.2)] hover:shadow-[0_0_30px_rgba(0,229,255,0.3)] hover:-translate-y-0.5' : 'border border-white/10 text-muted-100 hover:border-white/20 hover:bg-white/[0.04]'}`}>{cta}</a>
</div>
