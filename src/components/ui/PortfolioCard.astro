---
interface Props { title: string; category: string; description: string; tags: string[]; gradient: string; url?: string; live?: boolean; }
const { title, category, description, tags, gradient, url } = Astro.props;
const isExternal = url?.startsWith('http');
const domain = isExternal ? url!.replace(/^https?:\/\//, '').replace(/\/$/, '') : null;
const screenshotUrl = isExternal ? `https://api.microlink.io/?url=${encodeURIComponent(url!)}&screenshot=true&meta=false&embed=screenshot.url` : null;

const projectData = JSON.stringify({ title, category, description, tags, url, isExternal, screenshotUrl, gradient });
---
<div
  class="portfolio-card block glow-frame panel-highlight glass-hover group overflow-hidden rounded-xl hover:-translate-y-1 transition-transform duration-300 cursor-pointer"
  data-project={projectData}
>
  <div class={`relative h-56 overflow-hidden bg-gradient-to-br ${gradient}`}>
    {isExternal && screenshotUrl && (
      <img
        src={screenshotUrl}
        alt={`Screenshot of ${title}`}
        class="w-full h-full object-cover object-top"
        loading="lazy"
      />
    )}
    {url && !isExternal && (
      <div class="absolute inset-0 overflow-hidden">
        <iframe
          src={url}
          class="w-[1280px] h-[800px] border-0 pointer-events-none"
          style="transform: scale(0.28); transform-origin: top left;"
          loading="lazy"
          sandbox="allow-same-origin"
          tabindex="-1"
          title={`Preview of ${title}`}
        ></iframe>
      </div>
    )}
    {!url && (
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="text-4xl font-heading font-bold text-white/20">{title.split(' ').map((w: string) => w[0]).join('')}</span>
      </div>
    )}
    {isExternal && (
      <div class="absolute top-3 right-3 z-20">
        <span class="inline-flex items-center gap-1.5 rounded-lg bg-emerald-400/[0.15] backdrop-blur-sm px-2.5 py-1 text-xs font-semibold text-emerald-400 border border-emerald-400/20">
          <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          Live
        </span>
      </div>
    )}
    <div class="absolute inset-0 flex items-center justify-center bg-space-900/0 opacity-0 transition-all group-hover:bg-space-900/60 group-hover:opacity-100 z-10">
      <span class="flex items-center gap-2 text-sm font-heading font-semibold text-white bg-white/10 backdrop-blur-sm px-4 py-2 rounded-lg border border-white/20">
        View Project
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
      </span>
    </div>
  </div>
  {isExternal && domain && (
    <div class="flex items-center gap-2 px-4 py-2 border-b border-white/[0.06] bg-space-800/60">
      <svg class="w-3 h-3 text-emerald-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
      <span class="text-xs font-mono text-muted-300 truncate">{domain}</span>
    </div>
  )}
  <div class="p-6">
    <div class="flex items-center gap-2 mb-3">
      <span class="text-xs font-medium text-neon-cyan bg-neon-cyan/10 px-2 py-1 rounded-full">{category}</span>
    </div>
    <h3 class="text-lg font-heading font-bold text-muted-100 mb-2">{title}</h3>
    <p class="text-sm text-muted-200 leading-relaxed mb-4">{description}</p>
    <div class="flex flex-wrap gap-2">
      {tags.map((t: string) => <span class="text-xs text-muted-300 bg-space-600/50 px-2 py-1 rounded">{t}</span>)}
    </div>
  </div>
</div>
