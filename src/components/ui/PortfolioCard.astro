---
interface Props { title: string; category: string; description: string; tags: string[]; gradient: string; url?: string; live?: boolean; }
const { title, category, description, tags, gradient, url } = Astro.props;
const Tag = url ? 'a' : 'div';
const isExternal = url?.startsWith('http');
const linkProps = url ? { href: url, target: isExternal ? '_blank' : '_self', rel: isExternal ? 'noopener noreferrer' : undefined } : {};
const previewUrl = url || '#';
const screenshotUrl = isExternal ? `https://api.microlink.io/?url=${encodeURIComponent(url!)}&screenshot=true&meta=false&embed=screenshot.url` : null;
---
<Tag {...linkProps} class={`block glow-frame panel-highlight glass-hover group overflow-hidden rounded-xl hover:-translate-y-1 transition-transform duration-300 ${url ? 'cursor-pointer' : ''}`}>
  <div class={`relative h-56 overflow-hidden bg-gradient-to-br ${gradient}`}>
    <!-- External site: screenshot image -->
    {isExternal && screenshotUrl && (
      <img
        src={screenshotUrl}
        alt={`Screenshot of ${title}`}
        class="w-full h-full object-cover object-top"
        loading="lazy"
      />
    )}
    <!-- Internal demo: iframe preview -->
    {url && !isExternal && (
      <div class="absolute inset-0 overflow-hidden">
        <iframe
          src={previewUrl}
          class="w-[1280px] h-[800px] border-0 pointer-events-none"
          style="transform: scale(0.28); transform-origin: top left;"
          loading="lazy"
          sandbox="allow-same-origin"
          tabindex="-1"
          title={`Preview of ${title}`}
        ></iframe>
      </div>
    )}
    {!url && (
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="text-4xl font-heading font-bold text-white/20">{title.split(' ').map(w => w[0]).join('')}</span>
      </div>
    )}
    <!-- Live badge for external sites -->
    {isExternal && (
      <div class="absolute top-3 right-3 z-20">
        <span class="inline-flex items-center gap-1.5 rounded-lg bg-emerald-400/[0.15] backdrop-blur-sm px-2.5 py-1 text-xs font-semibold text-emerald-400 border border-emerald-400/20">
          <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          Live
        </span>
      </div>
    )}
    <!-- Hover overlay -->
    <div class="absolute inset-0 flex items-center justify-center bg-space-900/0 opacity-0 transition-all group-hover:bg-space-900/60 group-hover:opacity-100 z-10">
      <span class="flex items-center gap-2 text-sm font-heading font-semibold text-white bg-white/10 backdrop-blur-sm px-4 py-2 rounded-lg border border-white/20">
        {isExternal ? 'Visit Site' : 'View Demo'}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
      </span>
    </div>
  </div>
  <div class="p-6">
    <div class="flex items-center gap-2 mb-3">
      <span class="text-xs font-medium text-neon-cyan bg-neon-cyan/10 px-2 py-1 rounded-full">{category}</span>
    </div>
    <h3 class="text-lg font-heading font-bold text-muted-100 mb-2">{title}</h3>
    <p class="text-sm text-muted-200 leading-relaxed mb-4">{description}</p>
    <div class="flex flex-wrap gap-2">
      {tags.map(t => <span class="text-xs text-muted-300 bg-space-600/50 px-2 py-1 rounded">{t}</span>)}
    </div>
  </div>
</Tag>
